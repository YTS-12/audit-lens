# ── 인증키 (운영에서는 AWS Secrets Manager 사용 권장) ──
OPENDART_API_KEY=여기에_오픈다트_키
KRX_API_KEY=여기에_KRX_OpenAPI_키
ANTHROPIC_API_KEY=여기에_Claude_API_키

# ── 저장 경로 ──
DATA_DIR=./data

# ── 수집 파라미터 ──
TARGET_MARKET=KOSPI          # 코스피 전용
YEARS_BACK=3                 # 최근 3개 사업연도
AS_OF_DATE=2026-06-24        # 유니버스 스냅샷 기준일 (재현성)
PIPELINE_VERSION=v1          # 데이터/실행 버전 태그

# ── 모델 (확정 기본값) ──
CLAUDE_MODEL_ROUTER=claude-haiku-4-5-20251001
CLAUDE_MODEL_WORKHORSE=claude-sonnet-4-6
CLAUDE_MODEL_HARD=claude-opus-4-8
EMBEDDING_MODEL=BAAI/bge-m3

# ── 호출 제어 ──
OPENDART_RATE_PER_SEC=2      # 초당 호출 상한(레이트리밋)
HTTP_TIMEOUT=30
HTTP_MAX_RETRY=4

# ── Phase 0 ──
PHASE0_SAMPLE_SIZE=500       # 약 500 표본
